# Minimal NAS configuration for the current A/B setup:
# NAS daughter_detector remains active while RV1106 events arrive over MQTT.
# Values omitted here use config.py defaults. In particular, all LLAMA_* and
# ANALYSIS_PROMPT settings can be omitted because this mode never calls a VLM.

# Service and storage
APP_HOST=0.0.0.0
APP_PORT=8000
WORKERS_ENABLED=true
DATA_DIR=/mnt/var
BUFFER_DIR=/mnt/var/buffer
NEXTCLOUD_OUTPUT_DIR=/mnt/nextcloud-family-moments
DATABASE_PATH=/mnt/var/app.sqlite3

# Camera and recording
CAMERA_NAME=home-camera
RTSP_USERNAME=camera-user
RTSP_PASSWORD=camera-password
RTSP_LOW_URL=rtsp://camera-ip/stream2
RTSP_HIGH_URL=rtsp://camera-ip/stream1
RTSP_TRANSPORT=tcp
SEGMENT_SECONDS=120
SEGMENT_STABLE_SECONDS=8
SEGMENT_AT_CLOCKTIME=true
RETENTION_HOURS=72
RECORD_WINDOW_START=07:00
RECORD_WINDOW_END=21:00
ANALYSIS_WINDOW_START=07:00
ANALYSIS_WINDOW_END=21:00

# NAS detector used as the A/B baseline
ANALYSIS_ENABLED=true
ANALYSIS_BACKEND=daughter_detector
ANALYSIS_STREAM_ROLE=low
ANALYSIS_DELAY_SECONDS=300
DAUGHTER_DETECTOR_MODE=heuristic
DAUGHTER_SCAN_FPS=0.25
DAUGHTER_EVENT_MIN_HITS=2
DAUGHTER_EVENT_MAX_GAP_SECONDS=6
DAUGHTER_EVENT_MIN_SECONDS=4
DAUGHTER_AGE_CHECK_EVERY=1
DAUGHTER_BODY_HEIGHT_RATIO=0.65
DAUGHTER_BODY_AREA_RATIO=0.40
PERSON_FILTER_BACKEND=yolov11n
PERSON_FILTER_THRESHOLD=0.3
PERSON_FILTER_FACE_THRESHOLD=0.7
PERSON_FILTER_ADULT_THRESHOLD=0.9

# Clip selection. These caps apply jointly to NAS and RV1106 clips.
MAX_MOMENTS_PER_DAY=24
MAX_MOMENTS_PER_PERIOD=8
MOMENT_PERIOD_BOUNDARIES=07:00,12:00,17:00,21:00
MOMENT_COOLDOWN_SECONDS=300
MOMENT_CATEGORY_TARGETS=active:3,multi_person:3,quiet:2
CONTEXT_BEFORE_SECONDS=8
CONTEXT_AFTER_SECONDS=10
MAX_MOMENT_SECONDS=45
CLIP_VIDEO_CODEC=copy
CLIP_AUDIO_CODEC=copy

# RV1106 MQTT and seven-day A/B comparison
MQTT_ENABLED=true
MQTT_HOST=192.168.123.206
MQTT_PORT=1883
MQTT_USERNAME=nas-video
MQTT_PASSWORD=change-me
MQTT_DAUGHTER_TOPIC=homecam/daughter/hit
MQTT_STATUS_TOPIC=homecam/daughter/status
MQTT_CLIENT_ID=nas-video-home-camera
RV1106_SESSION_TIMEOUT_SECONDS=20
RV1106_ACCEPT_PROBABLE=true
DETECTOR_COMPARISON_ENABLED=true
DETECTOR_COMPARISON_DAYS=7
DETECTOR_CONTROL_SAMPLES_PER_DAY=6
DETECTOR_CONTROL_CLIP_SECONDS=20
