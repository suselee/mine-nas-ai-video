#!/bin/sh

NAME=daughter_watch
RUNNER=/root/daughter_watch/run.sh
PIDFILE=/var/run/daughter_watch.pid

is_running() {
    [ -s "$PIDFILE" ] || return 1
    pid=$(cat "$PIDFILE")
    kill -0 "$pid" 2>/dev/null
}

start() {
    is_running && return 0
    rm -f "$PIDFILE"
    [ -x "$RUNNER" ] || return 1
    start-stop-daemon -S -b -m -p "$PIDFILE" -x "$RUNNER"
}

stop() {
    if is_running; then
        start-stop-daemon -K -p "$PIDFILE" -s TERM -o
        i=0
        while is_running && [ "$i" -lt 20 ]; do sleep 1; i=$((i + 1)); done
    fi
    rm -f "$PIDFILE"
}

case "$1" in
    start) start ;;
    stop) stop ;;
    restart) stop; start ;;
    status) is_running ;;
    *) echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
