APP_HOST=0.0.0.0
APP_PORT=8000
WORKERS_ENABLED=true

DATA_DIR=./var
BUFFER_DIR=./var/buffer
NEXTCLOUD_OUTPUT_DIR=/mnt/nextcloud-family-moments
DATABASE_PATH=./var/app.sqlite3

CAMERA_NAME=home-camera
RTSP_USERNAME=camera-user
RTSP_PASSWORD=camera-password
RTSP_LOW_URL=rtsp://camera-ip/low-stream
RTSP_HIGH_URL=rtsp://camera-ip/4k-stream
RTSP_TRANSPORT=tcp

FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
# Hardware acceleration for ffmpeg decode. Leave empty (default) for
# pure software decoding. Set to "vaapi" to use Intel QuickSync GPU
# decode (requires /dev/dri in the jail and ffmpeg built with VAAPI
# support - check with: ffmpeg -hwaccels 2>/dev/null | grep vaapi).
# Speeds up 4K HEVC decode by 5-10x for motion detection and frame
# extraction during nightly batch analysis.
FFMPEG_HWACCEL=
SEGMENT_SECONDS=120
SEGMENT_STABLE_SECONDS=8
RETENTION_HOURS=168

ANALYSIS_ENABLED=true
ANALYSIS_DELAY_SECONDS=300
ANALYSIS_INTERVAL_SECONDS=15
ANALYSIS_MAX_ATTEMPTS=3
# Seconds to sleep after each segment analysis (success or error).
# Lets the CPU cool between segments so a 4-core NAS doesn't sustain
# 100% load. With 120s segments the gap between segments is already
# ~60s, so 5s is enough for realtime analysis. Set higher (10-20) if
# the NAS runs hot.
ANALYSIS_COOLDOWN_SECONDS=5
# Which stream to analyze. "low" (default) analyzes the low-bitrate
# stream for CPU efficiency during realtime analysis. "high" analyzes
# the 4K stream directly - better accuracy because the LLM sees clear
# facial expressions, at the cost of heavier CPU per frame extraction.
# Recommended when analysis runs in a nightly batch window.
ANALYSIS_STREAM_ROLE=low
# Time window for analysis. Leave both empty to analyze all day.
# Set to your daytime hours so the LLM is not called at night (camera
# privacy mask / nobody home). Handles windows that cross midnight.
# Recommended for this setup (camera masks at 21:00):
ANALYSIS_WINDOW_START=07:00
ANALYSIS_WINDOW_END=21:00
# Recording window. Leave both empty to record 24/7. Set to daytime
# hours so RTSP is not pulled and no black buffer is written while the
# camera is masked at night. The recorder pauses and resumes automatically.
# Recommended for this setup:
RECORD_WINDOW_START=07:00
RECORD_WINDOW_END=21:00
ANALYSIS_IMAGE_MODE=contact_sheet
ANALYSIS_FRAME_WIDTH=320
CONTACT_SHEET_COLUMNS=2
CONTACT_SHEET_PADDING=8
SAMPLE_FRAME_COUNT=6
SAMPLE_EVERY_SECONDS=30
# Sampling strategy. "even" (default) samples offsets evenly across the
# segment. "motion_aware" runs a cheap ffmpeg scene-detection pass first
# (no JPEG written, only pts timestamps of high-motion frames are parsed)
# then biases sampling toward motion moments while keeping at least one
# static baseline frame per time bucket - so a child drawing quietly is
# still captured, but an empty static room gets fewer frames and the LLM
# can more reliably judge keep=false.
SAMPLE_MODE=even
MOTION_THRESHOLD=0.02
# contact_sheet mode samples 1 chronological sheet per segment. A 2B
# vision model has trouble judging motion from a few low-res frames, so
# it tends to keep static/empty rooms. If accuracy is still low, raise
# SAMPLE_FRAME_COUNT to 8 and set ANALYSIS_IMAGE_MODE=frames to give
# the model more, clearer keyframes per segment.
# Keep a clip only when keep=true AND confidence >= this. 0.5 is a
# balanced default that keeps genuine family interactions / her own
# activities without hoarding every flat clip. Lower = save more.
MOMENT_KEEP_THRESHOLD=0.5
# Daily cap of saved moments (keep-best-N). 0 = unlimited. Set ~20 to
# bound disk and keep only the best ~10-20 clips per day.
MAX_MOMENTS_PER_DAY=20
CONTEXT_BEFORE_SECONDS=5
CONTEXT_AFTER_SECONDS=10
MAX_MOMENT_SECONDS=45

# Saved clips use -c copy by default (preserves the original RTSP
# codec/bitrate, fast and lossless). On 4K HEVC cameras the resulting
# mp4 is HEVC + AAC, which plays in VLC/mpv but NOT in Chrome/Firefox/
# Edge browsers (audio only). For browser playback set
# CLIP_VIDEO_CODEC=libx264 and CLIP_AUDIO_CODEC=aac to re-encode at
# extract time. Requires the ffmpeg package on this jail to include
# libx264 (notably NOT in FreeBSD's minimal ffmpeg build). Re-encoding
# 4K is slow on a NAS CPU; consider using the camera's H.264 substream
# for RTSP_HIGH_URL instead.
CLIP_VIDEO_CODEC=copy
CLIP_AUDIO_CODEC=copy
CLIP_VIDEO_PRESET=veryfast
CLIP_VIDEO_CRF=23

LLAMA_BASE_URL=http://llama-jail-ip:8080/v1
LLAMA_API_KEY=
LLAMA_MODEL=Qwen3-VL-2B-Instruct
LLAMA_TIMEOUT_SECONDS=120
# ANALYSIS_PROMPT is intentionally left to the built-in default (tuned for
# a ~1.5yo: keeps family interactions and her own activities, drops only
# empty/low-value clips, aiming for ~10-20 good clips/day). Uncomment to
# override:
# ANALYSIS_PROMPT=Find short, precious everyday moments of my ~1.5-year-old daughter at home. There are three family members: my daughter (a toddler girl), her mom (a young adult woman, NOT the grandma), and her grandma (an older woman) - distinct people, do not confuse mom with grandma. KEEP a clip when my daughter is clearly visible AND something real is happening: she is interacting with family (playing, talking, cuddling, reading, eating together, reacting to someone) or doing something on her own (playing with a toy, cruising/walking, babbling, exploring, laughing). Warm family interaction IS a highlight - high energy is NOT required. EXCLUDE only: empty/static room with NO child; child sleeping/drowsy; passive feeding with zero interaction; child totally blank/idle; screen time; blurry/black frames; adult chores while child merely present and NOT engaging. If you cannot see my daughter clearly, that frame is keep=false. Aim for ~10-20 good clips per day. Return JSON only with keep, title, summary, tags, confidence, start_offset_seconds, and end_offset_seconds.

# -- Person filter (optional local pre-filter) --
# When PERSON_FILTER_ENABLED=true, sampled frames are scored locally (on
# the NAS itself, no separate service) for person detection before
# reaching the LLM. Segments where no person is detected in any frame are
# skipped entirely (no LLM call), saving GPU/CPU time on empty rooms.
# Segments with a person get their best frames selected for LLM analysis.
# Requires opencv (FreeBSD: pkg install py311-opencv py311-numpy).
# Backend "yolov11n" (default) is the fastest + most accurate on CPU;
# "yolov26n" is ~30% faster still but needs OpenCV 5 to load on the NAS
# (see docs/person-filter.md — falls back to keeping all frames on 4.x);
# "yolov8n" is the older proven model; "mobilenet_ssd" is the lighter but
# lower-accuracy fallback. Set PERSON_FILTER_MODEL_URL to use a custom
# YOLO ONNX export (overrides the built-in download).
# PERSON_FILTER_ENABLED=true
# PERSON_FILTER_BACKEND=yolov11n
# PERSON_FILTER_MODEL_URL=
# PERSON_FILTER_THRESHOLD=0.3
# PERSON_FILTER_SAMPLE_COUNT=12
