APP_HOST=0.0.0.0
APP_PORT=8000
WORKERS_ENABLED=true

DATA_DIR=./var
BUFFER_DIR=./var/buffer
NEXTCLOUD_OUTPUT_DIR=/mnt/nextcloud-family-moments
DATABASE_PATH=./var/app.sqlite3

CAMERA_NAME=home-camera
RTSP_USERNAME=camera-user
RTSP_PASSWORD=camera-password
RTSP_LOW_URL=rtsp://camera-ip/low-stream
RTSP_HIGH_URL=rtsp://camera-ip/4k-stream
RTSP_TRANSPORT=tcp

FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
SEGMENT_SECONDS=120
SEGMENT_STABLE_SECONDS=8
RETENTION_HOURS=168

ANALYSIS_ENABLED=true
ANALYSIS_DELAY_SECONDS=300
ANALYSIS_INTERVAL_SECONDS=15
ANALYSIS_MAX_ATTEMPTS=3
ANALYSIS_IMAGE_MODE=contact_sheet
ANALYSIS_FRAME_WIDTH=320
CONTACT_SHEET_COLUMNS=2
CONTACT_SHEET_PADDING=8
SAMPLE_FRAME_COUNT=4
SAMPLE_EVERY_SECONDS=30
MOMENT_KEEP_THRESHOLD=0.25
CONTEXT_BEFORE_SECONDS=5
CONTEXT_AFTER_SECONDS=10
MAX_MOMENT_SECONDS=45

# Saved clips are re-encoded to browser-friendly codecs by default.
# 4K RTSP streams are commonly HEVC, which Chrome/Firefox/Edge cannot
# decode - the mp4 would play audio only. Re-encode keeps clips short
# and seekable in the web UI. Set CLIP_VIDEO_CODEC=copy (and audio too)
# to skip re-encode and keep the original RTSP codec/bitrate.
CLIP_VIDEO_CODEC=libx264
CLIP_AUDIO_CODEC=aac
CLIP_VIDEO_PRESET=veryfast
CLIP_VIDEO_CRF=23

LLAMA_BASE_URL=http://llama-jail-ip:8080/v1
LLAMA_API_KEY=
LLAMA_MODEL=Qwen3-VL-2B-Instruct
LLAMA_TIMEOUT_SECONDS=120
ANALYSIS_PROMPT=Find short, precious indoor moments of my daughter in the living room. There are three family members at home: my daughter (a young girl), her mom (a young adult woman, NOT the grandma), and her grandma (an older woman) - these are three distinct people, do not confuse mom with grandma. Look for scenes where my daughter is visible and active: playing with her mom, playing with her grandma, moving around, or interacting clearly with someone. Only keep clips where my daughter is visible and the scene is indoors. Skip empty rooms, outdoor views, pets-only, blurry frames, and background activity with no child. When describing the scene, name the family members correctly: daughter, mom, or grandma. Prefer genuine childhood moments but keep clips concise. Return JSON only with keep, title, summary, tags, confidence, start_offset_seconds, and end_offset_seconds.
